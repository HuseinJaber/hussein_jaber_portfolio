# Copy to .env on Hostinger (api.huseinjaber.com) — do not commit real secrets.

APP_NAME="Hussein Jaber Portfolio"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.huseinjaber.com

FRONTEND_URL=https://huseinjaber.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@huseinjaber.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_OWNER_ADDRESS="HusseinJaber5@hotmail.com"

PORTFOLIO_REGISTRATION_ENABLED=false
